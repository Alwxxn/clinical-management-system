  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "doctorToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "receptionistToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "pharmacistToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "labtechToken",
      "value": "",
